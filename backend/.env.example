PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/resume-architect
JWT_SECRET=replace-with-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
# Comma-separated allowed browser origins in production. In development, any
# http(s)://localhost or 127.0.0.1 with any port is allowed even if not listed.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Optional: AI features use OpenAI-compatible Chat Completions. If omitted, heuristic fallbacks apply.
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini
